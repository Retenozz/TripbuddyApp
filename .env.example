# ─── Supabase ─────────────────────────────────────────────────────────────────
# วิธีหา key:
#   1. เปิด https://supabase.com/dashboard
#   2. เลือก Project ของคุณ
#   3. ไปที่ Settings (เฟือง) > API
#   4. ก็อป "Project URL" ใส่ EXPO_PUBLIC_SUPABASE_URL
#   5. ก็อป "anon / public" key ใส่ EXPO_PUBLIC_SUPABASE_ANON_KEY
#      ⚠️ key ที่ถูกต้องจะขึ้นต้นด้วย eyJ... (เป็น JWT ยาวมาก)
#      ❌ ถ้าขึ้นต้นด้วย sb_publishable_ แสดงว่าก็อปผิด key
#
EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
